{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$ref": "#/definitions/Welcome",
    "definitions": {
        "Requirements": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "title": "Requirements"
        },
        "Welcome": {
            "type": "object",
            "properties": {
                "authors": {
                    "type": "string"
                },
                "categories": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "description": {
                    "type": "string"
                },
                "documentation_url": {
                    "type": "string",
                    "format": "uri"
                },
                "external_url": {
                    "type": "string",
                    "format": "uri"
                },
                "logo": {
                    "type": "string",
                    "format": "uri",
                    "qt-uri-protocols": [
                        "https"
                    ]
                },
                "requires": {
                    "type": "object",
                    "patternProperties": {
                        ".*": {
                            "$ref": "#/definitions/Requirements"
                        }
                    }
                },
                "state": {
                    "type": "string",
                    "enum": [
                        "registered",
                        "development",
                        "stable"
                    ]
                },
                "title": {
                    "type": "string"
                },
                "version": {
                    "type": "string"
                },
                "citations": {
                    "type": "array",
                    "items": {
                        "oneOf": [
                            {"$ref": "#/definitions/CitationSimple"},
                            {"$ref": "#/definitions/CitationStandard"}
                        ]
                    }
                }
            },
            "additionalProperties": false,
            "required": [
                "description",
                "title"
            ],
            "title": "Welcome"
        },
        "CitationSimple": {
            "type": "object",
            "properties": {
                "text": {
                    "type": "string"
                },
                "link": {
                    "type": "string",
                    "format": "uri"
                }
            },
            "additionalProperties": false,
            "required": [
                "text"
            ],
            "title": "CitationSimple"
        },
        "CitationStandard": {
            "type": "object",
            "properties": {
                "authors": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "journal": {
                    "type": "string"
                },
                "year": {
                    "type": "string"
                },
                "doi": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                },
                "volume": {
                    "type": "string"
                },
                "issue": {
                    "type": "string"
                }
            },
            "additionalProperties": false,
            "required": [
                "authors",
                "journal",
                "year",
                "doi"
            ],
            "title": "CitationStandard"
        }
    }
}
